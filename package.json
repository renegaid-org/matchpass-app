{
  "name": "matchpass-gate",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Stateless gate verification server for MatchPass",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node server/index.js",
    "dev:client": "cd client && npm run dev",
    "build:client": "cd client && npm run build",
    "install:client": "cd client && npm install",
    "test": "vitest run",
    "test:client": "cd client && npm run test",
    "test:watch": "vitest",
    "typecheck:client": "cd client && npm run typecheck"
  },
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.4.1",
    "nostr-tools": "^2.10.4",
    "@noble/curves": "^1.8.1",
    "@noble/hashes": "^1.7.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "vitest": "^4.1.5"
  }
}
